rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'fannywang062igs@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Groups
    match /groups/{groupId} {
      allow read: if true; // Public view
      allow write: if isAdmin(); // Only YOU can modify
      
      function isValidGroup(data) {
        return data.id is string && data.group is string && data.group.size() <= 200;
      }

      allow create: if isAdmin() && isValidGroup(incoming()) && isValidId(groupId);
      allow update: if isAdmin() && isValidGroup(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Items
    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();

      function isValidItem(data) {
        return data.id is string && data.groupId is string && data.title is string && data.title.size() <= 200;
      }

      allow create: if isAdmin() && isValidItem(incoming()) && isValidId(itemId);
      allow update: if isAdmin() && isValidItem(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // Config
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sections
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();

      function isValidSection(data) {
        return data.id is string && data.itemId is string && data.title is string && data.type in ['list', 'important', 'steps', 'details'];
      }

      allow create: if isAdmin() && isValidSection(incoming()) && isValidId(sectionId);
      allow update: if isAdmin() && isValidSection(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }
  }
}
