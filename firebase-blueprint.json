{
  "entities": {
    "Group": {
      "title": "Manual Group",
      "description": "A top-level category of manual items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "group": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["id", "group"]
    },
    "Item": {
      "title": "Manual Item",
      "description": "A specific manual item within a group.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "updatedAt": { "type": "number" },
        "order": { "type": "integer" }
      },
      "required": ["id", "groupId", "title"]
    },
    "Section": {
      "title": "Item Section",
      "description": "A section of content within a manual item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["list", "important", "steps", "details"] },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image"] },
              "value": { "type": "string" },
              "isBold": { "type": "boolean" },
              "width": { "type": "number" }
            }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "order": { "type": "integer" }
      },
      "required": ["id", "itemId", "title", "type"]
    },
    "Config": {
      "title": "App Configuration",
      "description": "General application settings like header title and home page blocks.",
      "type": "object",
      "properties": {
        "headerTitle": { "type": "string" },
        "headerSubtitle": { "type": "string" },
        "headerDescription": { "type": "string" },
        "homeBlocks": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/config/{configId}": {
      "schema": "Config",
      "description": "General app settings"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Manual categories"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Specific guide documents"
    },
    "/sections/{sectionId}": {
      "schema": "Section",
      "description": "Content blocks for items"
    }
  }
}
